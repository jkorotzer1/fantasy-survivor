<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
  <head>
    <title>Fantasy Survivor</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <script>if(localStorage.getItem('darkMode')==='true'){document.documentElement.classList.add('dark')}</script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="h-full">
    <nav class="bg-green-800 shadow">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center">
            <%= link_to "🌴 Fantasy Survivor", root_path, class: "text-white text-xl font-bold" %>
            <!-- desktop nav links -->
            <div class="hidden md:flex ml-8 space-x-4">
              <%= link_to "Seasons", seasons_path, class: "text-green-200 hover:text-white px-3 py-2 text-sm font-medium" %>
              <%= link_to "Rules & Scoring", rules_path, class: "text-green-200 hover:text-white px-3 py-2 text-sm font-medium" %>
              <%= link_to "Board", board_path, class: "text-green-200 hover:text-white px-3 py-2 text-sm font-medium" %>
              <% if current_user&.admin? %>
                <%= link_to "Admin", admin_root_path, class: "text-yellow-300 hover:text-yellow-100 px-3 py-2 text-sm font-medium" %>
              <% end %>
            </div>
          </div>
          <!-- desktop user controls -->
          <div class="hidden md:flex items-center space-x-4">
            <button onclick="toggleDark()" id="dark-toggle"
                    class="text-green-200 hover:text-white text-sm px-3 py-1 rounded border border-green-600 hover:border-green-400">Dark Mode</button>
            <% if user_signed_in? %>
              <span class="text-green-200 text-sm"><%= current_user.display_name %></span>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete,
                  class: "text-green-200 hover:text-white text-sm font-medium bg-transparent border-0 cursor-pointer p-0" %>
            <% else %>
              <%= link_to "Sign In", new_user_session_path, class: "text-green-200 hover:text-white text-sm font-medium" %>
              <%= link_to "Register", new_user_registration_path, class: "bg-green-600 text-white px-3 py-2 rounded text-sm font-medium hover:bg-green-500" %>
            <% end %>
          </div>
          <!-- hamburger button — mobile only -->
          <button onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
                  class="md:hidden text-green-200 hover:text-white focus:outline-none text-2xl leading-none px-2">
            ☰
          </button>
        </div>
      </div>
      <!-- mobile menu panel -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-green-700 pb-3 pt-2">
        <div class="mx-auto max-w-7xl px-4 space-y-1">
          <%= link_to "Seasons", seasons_path, class: "block text-green-200 hover:text-white px-3 py-2 text-sm font-medium rounded" %>
          <%= link_to "Rules & Scoring", rules_path, class: "block text-green-200 hover:text-white px-3 py-2 text-sm font-medium rounded" %>
          <%= link_to "Board", board_path, class: "block text-green-200 hover:text-white px-3 py-2 text-sm font-medium rounded" %>
          <% if current_user&.admin? %>
            <%= link_to "Admin", admin_root_path, class: "block text-yellow-300 hover:text-yellow-100 px-3 py-2 text-sm font-medium rounded" %>
          <% end %>
          <div class="border-t border-green-700 mt-2 pt-2 space-y-1">
            <button onclick="toggleDark()" id="dark-toggle-mobile"
                    class="block text-green-200 hover:text-white text-sm px-3 py-2 font-medium">Dark Mode</button>
            <% if user_signed_in? %>
              <span class="block text-green-300 px-3 py-1 text-sm"><%= current_user.display_name %></span>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete,
                  class: "block text-green-200 hover:text-white text-sm font-medium bg-transparent border-0 cursor-pointer px-3 py-2" %>
            <% else %>
              <%= link_to "Sign In", new_user_session_path, class: "block text-green-200 hover:text-white px-3 py-2 text-sm font-medium rounded" %>
              <%= link_to "Register", new_user_registration_path, class: "inline-block bg-green-600 text-white px-3 py-2 rounded text-sm font-medium hover:bg-green-500 mx-3" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <% flash.each do |type, message| %>
        <% css_class = type.to_s == "alert" ? "bg-red-100 text-red-800 border-red-300" : "bg-green-100 text-green-800 border-green-300" %>
        <div class="mb-4 rounded border px-4 py-3 <%= css_class %>">
          <%= message %>
        </div>
      <% end %>

      <%= yield %>
    </main>
    <script>
      function toggleDark() {
        var dark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('darkMode', dark);
        syncDarkIcon();
      }
      function syncDarkIcon() {
        var label = document.documentElement.classList.contains('dark') ? 'Light Mode' : 'Dark Mode';
        var btn = document.getElementById('dark-toggle');
        if (btn) btn.textContent = label;
        var btnM = document.getElementById('dark-toggle-mobile');
        if (btnM) btnM.textContent = label;
      }
      document.addEventListener('turbo:load', syncDarkIcon);
      syncDarkIcon();
    </script>
  </body>
</html>
