<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Winner Pick</h1>
    <p class="text-gray-500"><%= @season.name %> — This cannot be changed once submitted!</p>
  </div>
  <%= link_to "Cancel", season_path(@season), class: "text-gray-500 hover:text-gray-700 text-sm" %>
</div>

<!-- Points table -->
<div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6 max-w-xl">
  <h3 class="font-semibold text-yellow-800 mb-2 text-sm">
    Points by Week Picked
    <% current_wk = @season.current_winner_pick_week %>
    <% current_pts = WinnerPick::POINTS_BY_WEEK.fetch(current_wk&.number, 0) %>
    — <span class="text-yellow-900">picking now (Week <%= current_wk&.number %>) is worth <strong><%= current_pts %> pts</strong> if correct</span>
  </h3>
  <div class="grid grid-cols-4 gap-1 text-xs text-yellow-700">
    <% WinnerPick::POINTS_BY_WEEK.each do |week_num, pts| %>
      <div class="bg-yellow-100 rounded px-2 py-1 text-center">
        <div class="font-bold">Wk <%= week_num %></div>
        <div><%= pts %> pts</div>
      </div>
    <% end %>
  </div>
  <p class="text-xs text-yellow-600 mt-2">Pick early = more points if correct</p>
</div>

<div class="bg-white shadow rounded-lg p-6 max-w-xl">
  <% if @pick.errors.any? %>
    <div class="mb-4 bg-red-50 border border-red-200 rounded p-3">
      <ul class="text-red-700 text-sm list-disc pl-4">
        <% @pick.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @pick, url: season_winner_picks_path(@season) do |f| %>
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 mb-2">Who will win Survivor <%= @season.number %>?</label>
      <div class="space-y-2">
        <% @contestants.order(:name).each do |contestant| %>
          <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50">
            <%= f.radio_button :contestant_id, contestant.id, class: "text-yellow-500" %>
            <span class="text-sm text-gray-800"><%= contestant.name %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="bg-orange-50 border border-orange-200 rounded p-3 mb-4">
      <p class="text-orange-800 text-sm font-medium">⚠️ This cannot be changed after submitting.</p>
    </div>

    <%= f.submit "Lock In Winner Pick", class: "bg-yellow-600 text-white px-6 py-2 rounded font-medium hover:bg-yellow-500 cursor-pointer" %>
  <% end %>
</div>
