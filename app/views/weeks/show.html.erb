<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Week <%= @week.number %></h1>
    <p class="text-gray-500">
      <%= @season.name %>
      <% if @week.air_date %> · Aired <%= @week.air_date.strftime("%B %d, %Y") %><% end %>
    </p>
  </div>
  <%= link_to "← Season", season_path(@season), class: "text-green-700 hover:text-green-600 text-sm" %>
</div>

<div class="grid gap-8 lg:grid-cols-3">
  <!-- Pick section -->
  <div class="lg:col-span-2">
    <% if @participation %>
      <div class="bg-white shadow rounded-lg p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">Your Pick</h2>

        <% if @week.locked? %>
          <div class="bg-red-50 border border-red-200 rounded p-3 mb-4">
            <p class="text-red-700 text-sm font-medium">
              Picks are locked. Locked at <%= @week.picks_locked_at.in_time_zone("Eastern Time (US & Canada)").strftime("%B %d at %I:%M %p ET") %>.
            </p>
          </div>
          <% if @existing_pick %>
            <p class="text-gray-700 mb-3">You picked: <strong><%= @existing_pick.contestant.name %></strong></p>
            <% pick_events = @scoring_events[@existing_pick.contestant] || [] %>
            <% if pick_events.any? %>
              <div class="border-t border-gray-100 pt-3">
                <p class="text-xs font-semibold text-gray-500 uppercase mb-2">
                  <%= @existing_pick.contestant.name %>'s Events
                  <% unless @week.scored? %><span class="text-yellow-600 font-normal normal-case ml-1">(in progress)</span><% end %>
                </p>
                <div class="space-y-1">
                  <% pick_events.each do |event| %>
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-gray-600"><%= event.label %></span>
                      <span class="font-medium <%= event.point_value > 0 ? 'text-green-600' : 'text-red-600' %>">
                        <%= event.point_value > 0 ? "+#{event.point_value}" : event.point_value %>
                      </span>
                    </div>
                  <% end %>
                  <% total = pick_events.sum(&:point_value) %>
                  <div class="flex items-center justify-between text-sm font-bold border-t border-gray-200 pt-1 mt-1">
                    <span class="text-gray-700">Your score this week</span>
                    <span class="<%= total > 0 ? 'text-green-700' : total < 0 ? 'text-red-600' : 'text-gray-500' %>">
                      <%= total > 0 ? "+#{total}" : total %>
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500">You didn't make a pick for this week.</p>
          <% end %>
        <% else %>

          <% if @existing_pick %>
            <div class="bg-green-50 border border-green-200 rounded p-3 mb-4">
              <p class="text-green-800 text-sm">Current pick: <strong><%= @existing_pick.contestant.name %></strong></p>
            </div>
          <% end %>

          <%= link_to @existing_pick ? "Change Pick" : "Make Pick",
              new_season_week_weekly_pick_path(@season, @week),
              class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600" %>
          <p class="mt-3 text-xs text-gray-400">Picks lock at 8:00 PM Eastern on the night of the episode.</p>
        <% end %>
      </div>
    <% elsif user_signed_in? %>
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
        <p class="text-yellow-800 text-sm">
          <%= button_to "Join this season", season_participations_path(@season), method: :post,
              class: "font-semibold underline bg-transparent border-0 cursor-pointer p-0 text-yellow-800 text-sm" %>
          to make picks.
        </p>
      </div>
    <% end %>

    <!-- Scoring Events -->
    <% if @week.locked? %>
      <div class="bg-white shadow rounded-lg p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">
          Week Results
          <% unless @week.scored? %><span class="text-sm text-yellow-600 font-normal ml-2">(in progress)</span><% end %>
        </h2>
        <% @contestants.sort_by { |c| -(@scoring_events[c] || []).sum(&:point_value) }.each do |contestant| %>
          <% events = @scoring_events[contestant] || [] %>
          <% total = events.sum(&:point_value) %>
          <div class="mb-4">
            <h3 class="font-medium text-gray-700 mb-2">
              <%= contestant.name %>
              <span class="text-sm ml-2 <%= total > 0 ? 'text-green-600' : total < 0 ? 'text-red-600' : 'text-gray-400' %>">
                (<%= total > 0 ? "+#{total}" : total %> pts)
              </span>
            </h3>
            <% if events.any? %>
              <div class="pl-4 space-y-1">
                <% events.each do |event| %>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600"><%= event.label %></span>
                    <span class="<%= event.point_value > 0 ? 'text-green-600' : 'text-red-600' %> font-medium">
                      <%= event.point_value > 0 ? "+#{event.point_value}" : event.point_value %>
                    </span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% elsif @scoring_events.any? %>
      <div class="bg-white shadow rounded-lg p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">
          Week Results
          <span class="text-sm text-yellow-600 font-normal ml-2">(in progress)</span>
        </h2>
        <% @scoring_events.each do |contestant, events| %>
          <% total = events.sum(&:point_value) %>
          <div class="mb-4">
            <h3 class="font-medium text-gray-700 mb-2">
              <%= contestant.name %>
              <span class="text-sm ml-2 <%= total > 0 ? 'text-green-600' : total < 0 ? 'text-red-600' : 'text-gray-400' %>">
                (<%= total > 0 ? "+#{total}" : total %> pts)
              </span>
            </h3>
            <div class="pl-4 space-y-1">
              <% events.each do |event| %>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-600"><%= event.label %></span>
                  <span class="<%= event.point_value > 0 ? 'text-green-600' : 'text-red-600' %> font-medium">
                    <%= event.point_value > 0 ? "+#{event.point_value}" : event.point_value %>
                  </span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Sidebar -->
  <div>
    <div class="bg-white shadow rounded-lg p-4">
      <h2 class="text-lg font-semibold text-gray-800 mb-2">Castaways</h2>
      <%
        tribe_colors = {
          "vatu" => { dot: "bg-purple-500" },
          "cila" => { dot: "bg-orange-500" },
          "calo" => { dot: "bg-teal-500"   },
        }
      %>
      <!-- header -->
      <div class="flex items-center pb-1 mb-1 border-b border-gray-200 text-xs font-medium text-gray-400 uppercase gap-2">
        <span class="w-4 shrink-0"></span>
        <span class="flex-1">Castaway</span>
        <span>Past Tribes</span>
      </div>
      <% @contestants.sort_by { |c| [-c.all_tribes.size, c.tribe.to_s, c.name] }.each do |contestant| %>
        <% current_colors = tribe_colors[contestant.tribe] %>
        <div class="flex items-center py-1 border-b border-gray-100 last:border-0 gap-2">
          <!-- current tribe dot -->
          <span class="w-4 shrink-0 flex justify-center">
            <% if current_colors %>
              <span class="inline-block w-2.5 h-2.5 rounded-full <%= current_colors[:dot] %>"></span>
            <% end %>
          </span>
          <!-- name -->
          <span class="flex-1 text-sm <%= contestant.eliminated? ? 'text-gray-400 line-through' : 'text-gray-700' %>">
            <%= contestant.name %>
          </span>
          <!-- past tribes -->
          <span class="flex flex-wrap justify-end gap-x-2 gap-y-0.5">
            <% Array(contestant.previous_tribes).each do |t| %>
              <% t_name = t.is_a?(Hash) ? t["name"].to_s : t.to_s %>
              <% t_from = t.is_a?(Hash) ? t["from"] : nil %>
              <% t_to   = t.is_a?(Hash) ? t["to"]   : nil %>
              <% colors = tribe_colors[t_name] %>
              <span class="flex items-center gap-1 whitespace-nowrap text-xs text-gray-500">
                <% if t_from || t_to %><span>Wk <%= t_from %>–<%= t_to %></span><% end %>
                <% if colors %><span class="inline-block w-2 h-2 rounded-full <%= colors[:dot] %>"></span><% end %>
              </span>
            <% end %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</div>
