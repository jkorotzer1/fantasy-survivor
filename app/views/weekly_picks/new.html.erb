<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= @pick.persisted? ? "Change Your Pick" : "Make Your Pick" %> — Week <%= @week.number %></h1>
    <p class="text-gray-500"><%= @season.name %></p>
  </div>
  <%= link_to "Cancel", season_week_path(@season, @week), class: "text-gray-500 hover:text-gray-700 text-sm" %>
</div>

<div class="bg-white shadow rounded-lg p-6 max-w-xl">
  <% if @pick.errors.any? %>
    <div class="mb-4 bg-red-50 border border-red-200 rounded p-3">
      <ul class="text-red-700 text-sm list-disc pl-4">
        <% @pick.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @pick,
        url: @pick.persisted? ? season_week_weekly_pick_path(@season, @week, @pick) : season_week_weekly_picks_path(@season, @week),
        method: @pick.persisted? ? :patch : :post do |f| %>
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 mb-2">Choose a Contestant</label>
      <p class="text-xs text-gray-500 mb-3">You can pick the same person at most twice per season.</p>

      <div class="space-y-2">
        <% @available_contestants.each do |contestant| %>
          <% maxed = @maxed_contestant_ids.include?(contestant.id) %>
          <% times_picked = @participation.weekly_picks.where(contestant: contestant).count %>
          <label class="flex items-center gap-3 p-3 border rounded-lg
            <%= maxed ? 'border-gray-100 bg-gray-50 opacity-50 cursor-not-allowed' : 'cursor-pointer hover:bg-gray-50' %>
            <%= !maxed && @pick.contestant_id == contestant.id ? 'border-green-500 bg-green-50' : 'border-gray-200' %>">
            <%= f.radio_button :contestant_id, contestant.id, class: "text-green-600", disabled: maxed %>
            <span class="flex-1 text-sm <%= maxed ? 'text-gray-400' : 'text-gray-800' %>"><%= contestant.name %></span>
            <% if maxed %>
              <span class="text-xs text-gray-400 font-medium">Picked 2×</span>
            <% elsif times_picked > 0 %>
              <span class="text-xs text-orange-600 font-medium">Used <%= times_picked %>×</span>
            <% end %>
          </label>
        <% end %>
      </div>

      <% if @available_contestants.empty? %>
        <p class="text-gray-500 text-sm">No available contestants. You've used all your picks!</p>
      <% end %>
    </div>

    <% unless @available_contestants.empty? %>
      <%= f.submit "Save Pick", class: "bg-green-700 text-white px-6 py-2 rounded font-medium hover:bg-green-600 cursor-pointer" %>
    <% end %>
  <% end %>
</div>
