<div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h1 class="text-center text-3xl font-bold text-gray-900">🌴 Fantasy Survivor</h1>
    <p class="mt-2 text-center text-sm text-gray-600">Sign in to your account</p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow rounded-lg sm:px-10">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
          </div>
          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
          </div>
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <%= f.check_box :remember_me, class: "rounded border-gray-300" %>
              Remember me
            </label>
            <%= link_to "Forgot password?", new_user_password_path, class: "text-sm text-green-700 hover:text-green-600" %>
          </div>
        </div>

        <div class="mt-6">
          <%= f.submit "Sign In", class: "w-full bg-green-700 text-white py-2 px-4 rounded font-medium hover:bg-green-600 cursor-pointer" %>
        </div>

        <p class="mt-4 text-center text-sm text-gray-600">
          New here? <%= link_to "Create an account", new_user_registration_path, class: "text-green-700 font-medium" %>
        </p>
      <% end %>
    </div>
  </div>
</div>
