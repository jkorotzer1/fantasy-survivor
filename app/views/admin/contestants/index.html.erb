<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Contestants</h1>
    <p class="text-gray-500"><%= @season.name %></p>
  </div>
  <div class="flex gap-2">
    <%= link_to "← Season", admin_season_path(@season), class: "text-gray-500 text-sm" %>
    <%= link_to "Add Contestant", new_admin_season_contestant_path(@season),
        class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600" %>
  </div>
</div>

<%= form_with url: bulk_assign_tribe_admin_season_contestants_path(@season), method: :post do |f| %>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left">
            <input type="checkbox" id="select-all" class="rounded border-gray-300 text-green-600">
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tribe</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Elim. Week</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @contestants.each do |contestant| %>
          <tr>
            <td class="px-4 py-4">
              <input type="checkbox" name="contestant_ids[]" value="<%= contestant.id %>" class="contestant-checkbox rounded border-gray-300 text-green-600">
            </td>
            <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= contestant.name %></td>
            <td class="px-6 py-4 text-sm text-gray-600">
              <% if contestant.tribe.present? %>
                <span class="font-medium"><%= contestant.tribe %></span>
                <% if contestant.tribe_from_week.present? %>
                  <span class="text-gray-400 text-xs ml-1">(Wk <%= contestant.tribe_from_week %>+)</span>
                <% end %>
              <% end %>
              <% Array(contestant.previous_tribes).each do |t| %>
                <% t_name = t.is_a?(Hash) ? t["name"] : t.to_s %>
                <div class="text-gray-400 text-xs">
                  <%= t_name %>
                  <% if t.is_a?(Hash) && (t["from"] || t["to"]) %>
                    (Wk <%= t["from"] %>–<%= t["to"] %>)
                  <% end %>
                </div>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                <%= contestant.active? ? 'bg-green-100 text-green-800' : contestant.winner? ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-600' %>">
                <%= contestant.active? ? '🔥' : contestant.winner? ? contestant.status.capitalize : '💀' %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= contestant.eliminated_week || "—" %></td>
            <td class="px-6 py-4 text-right text-sm space-x-2">
              <%= link_to "Edit", edit_admin_season_contestant_path(@season, contestant), class: "text-blue-600 hover:text-blue-500" %>
              <%= link_to "Delete", admin_season_contestant_path(@season, contestant),
                  data: { turbo_method: :delete, turbo_confirm: "Remove #{contestant.name}?" },
                  class: "text-red-600 hover:text-red-500" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>

  <div class="mt-4 bg-gray-50 border border-gray-200 rounded-lg p-4 flex flex-wrap items-end gap-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">New tribe name</label>
      <%= f.text_field :tribe, placeholder: "e.g. vatu", class: "rounded border-gray-300 shadow-sm text-sm px-3 py-2 w-36" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Starting week</label>
      <%= f.number_field :from_week, placeholder: "e.g. 5", min: 1, class: "rounded border-gray-300 shadow-sm text-sm px-3 py-2 w-24" %>
    </div>
    <%= f.submit "Assign Tribe", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-500 cursor-pointer" %>
    <p class="text-xs text-gray-500 self-end">Current tribe is closed out at (starting week − 1) and moved to history.</p>
  </div>
<% end %>

<script>
  document.getElementById('select-all').addEventListener('change', function() {
    document.querySelectorAll('.contestant-checkbox').forEach(cb => cb.checked = this.checked);
  });
</script>
