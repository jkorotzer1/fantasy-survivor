<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Edit Weekly Pick</h1>
    <p class="text-gray-500"><%= @pick.participation.user.display_name %> — Week <%= @pick.week.number %> — <%= @pick.week.season.name %></p>
  </div>
  <%= link_to "← Score Board", scores_admin_season_path(@pick.week.season), class: "text-gray-500 text-sm" %>
</div>

<div class="bg-white shadow rounded-lg p-6 max-w-sm">
  <% if @pick.errors.any? %>
    <div class="mb-4 bg-red-50 border border-red-200 rounded p-3">
      <ul class="text-red-700 text-sm list-disc pl-4">
        <% @pick.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [:admin, @pick] do |f| %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Contestant</label>
      <%= f.select :contestant_id,
          @contestants.map { |c| ["#{c.name}#{' 💀' if c.eliminated?}#{' ★' if c.winner?}", c.id] },
          {},
          class: "block w-full rounded border-gray-300 shadow-sm text-sm" %>
    </div>
    <div class="flex gap-3">
      <%= f.submit "Save Pick", class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600 cursor-pointer" %>
      <%= link_to "Cancel", scores_admin_season_path(@pick.week.season), class: "text-gray-500 hover:text-gray-700 px-4 py-2 text-sm" %>
    </div>
  <% end %>
</div>
