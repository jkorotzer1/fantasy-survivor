<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Add Weekly Pick</h1>
    <p class="text-gray-500"><%= @participation.user.display_name %> — Week <%= @week.number %> — <%= @week.season.name %></p>
  </div>
  <%= link_to "← Score Board", scores_admin_season_path(@week.season), class: "text-gray-500 text-sm" %>
</div>

<div class="bg-white shadow rounded-lg p-6 max-w-sm">
  <%= form_with model: [:admin, @pick] do |f| %>
    <%= f.hidden_field :participation_id, value: @participation.id %>
    <%= f.hidden_field :week_id, value: @week.id %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Contestant</label>
      <%= f.select :contestant_id,
          @contestants.map { |c| ["#{c.name}#{' 💀' if c.eliminated?}#{' ★' if c.winner?}", c.id] },
          { prompt: "Select contestant..." },
          class: "block w-full rounded border-gray-300 shadow-sm text-sm" %>
    </div>
    <div class="flex gap-3">
      <%= f.submit "Add Pick", class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600 cursor-pointer" %>
      <%= link_to "Cancel", scores_admin_season_path(@week.season), class: "text-gray-500 hover:text-gray-700 px-4 py-2 text-sm" %>
    </div>
  <% end %>
</div>
