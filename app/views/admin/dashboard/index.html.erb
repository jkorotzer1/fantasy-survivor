<h1 class="text-2xl font-bold text-gray-900 mb-6">Admin Dashboard</h1>

<div class="grid gap-6 lg:grid-cols-3 mb-8">
  <div class="bg-white shadow rounded-lg p-5">
    <p class="text-gray-500 text-sm">Seasons</p>
    <p class="text-3xl font-bold text-gray-900 mt-1"><%= @seasons.count %></p>
    <%= link_to "Manage Seasons →", admin_seasons_path, class: "text-green-700 text-sm mt-2 inline-block" %>
  </div>
  <div class="bg-white shadow rounded-lg p-5">
    <p class="text-gray-500 text-sm">Pending Payments</p>
    <p class="text-3xl font-bold text-gray-900 mt-1"><%= @pending_payments.count %></p>
    <%= link_to "View All →", admin_participations_path, class: "text-green-700 text-sm mt-2 inline-block" %>
  </div>
</div>

<div class="grid gap-6 lg:grid-cols-2">
  <div class="bg-white shadow rounded-lg p-5">
    <h2 class="font-semibold text-gray-800 mb-3">Seasons</h2>
    <% @seasons.each do |season| %>
      <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
        <span class="text-sm text-gray-700"><%= season.name %></span>
        <div class="flex items-center gap-2">
          <span class="text-xs px-2 py-0.5 rounded-full <%= season.active? ? 'bg-green-100 text-green-800' : season.upcoming? ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-600' %>">
            <%= season.status %>
          </span>
          <%= link_to "Edit", admin_season_path(season), class: "text-blue-600 text-xs" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-5">
    <h2 class="font-semibold text-gray-800 mb-3">Pending Payments</h2>
    <% @pending_payments.each do |p| %>
      <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
        <div>
          <span class="text-sm text-gray-700"><%= p.user.display_name %></span>
          <span class="text-xs text-gray-400 ml-2"><%= p.season.name %></span>
        </div>
        <%= button_to "Mark Paid", admin_participation_path(p),
            method: :patch,
            params: { participation: { paid_in: true } },
            class: "text-xs bg-green-100 text-green-800 px-2 py-1 rounded hover:bg-green-200" %>
      </div>
    <% end %>
    <% if @pending_payments.empty? %>
      <p class="text-gray-400 text-sm">All caught up!</p>
    <% end %>
  </div>
</div>
