<% if event_type.errors.any? %>
  <div class="mb-4 bg-red-50 border border-red-200 rounded p-3">
    <ul class="text-red-700 text-sm list-disc pl-4">
      <% event_type.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-4">
  <div>
    <%= f.label :label, "Label", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :label, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm",
        placeholder: "e.g. Survived the Week" %>
  </div>

  <div>
    <%= f.label :key, "Key", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :key, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm font-mono",
        placeholder: "e.g. survived_week" %>
    <p class="text-xs text-gray-500 mt-1">Lowercase letters, numbers, and underscores only. Cannot be changed once scoring events use this key.</p>
  </div>

  <div>
    <%= f.label :points, "Points", class: "block text-sm font-medium text-gray-700" %>
    <%= f.number_field :points, class: "mt-1 block w-32 rounded border-gray-300 shadow-sm text-sm" %>
    <p class="text-xs text-gray-500 mt-1">Use negative numbers for penalties.</p>
  </div>

  <div class="flex gap-6">
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :is_elimination, class: "rounded border-gray-300" %>
      <span class="text-sm font-medium text-gray-700">Elimination event</span>
    </label>
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :is_winner, class: "rounded border-gray-300" %>
      <span class="text-sm font-medium text-gray-700">Winner event</span>
    </label>
  </div>
  <p class="text-xs text-gray-500 -mt-2">Elimination events auto-mark contestants as eliminated. Winner events auto-mark them as winner.</p>
</div>
