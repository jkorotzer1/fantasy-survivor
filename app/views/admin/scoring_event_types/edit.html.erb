<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Edit Event Type</h1>
  <p class="text-gray-500 text-sm mt-1">Key: <span class="font-mono"><%= @event_type.key %></span></p>
</div>

<div class="bg-white shadow rounded-lg p-6 max-w-lg">
  <%= form_with model: [:admin, @event_type] do |f| %>
    <%= render "form", f: f, event_type: @event_type %>
    <div class="mt-6 flex gap-3">
      <%= f.submit "Save Changes", class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600 cursor-pointer" %>
      <%= link_to "Cancel", admin_scoring_event_types_path, class: "text-gray-500 hover:text-gray-700 px-4 py-2 text-sm" %>
    </div>
  <% end %>
</div>
