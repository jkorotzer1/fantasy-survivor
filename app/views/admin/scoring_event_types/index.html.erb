<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Scoring Event Types</h1>
  <%= link_to "Add Event Type", new_admin_scoring_event_type_path,
      class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600" %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Label</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Key</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Points</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Elimination?</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Winner?</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @event_types.each do |et| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= et.label %></td>
          <td class="px-4 py-3 text-sm text-gray-500 font-mono"><%= et.key %></td>
          <td class="px-4 py-3 text-sm text-center font-semibold <%= et.points >= 0 ? 'text-green-700' : 'text-red-600' %>">
            <%= et.points_display %>
          </td>
          <td class="px-4 py-3 text-center text-sm">
            <%= et.is_elimination? ? "✓" : "" %>
          </td>
          <td class="px-4 py-3 text-center text-sm">
            <%= et.is_winner? ? "✓" : "" %>
          </td>
          <td class="px-4 py-3 text-right text-sm flex gap-3 justify-end">
            <%= link_to "Edit", edit_admin_scoring_event_type_path(et), class: "text-blue-600 hover:text-blue-500" %>
            <%= button_to "Delete", admin_scoring_event_type_path(et), method: :delete,
                data: { turbo_confirm: "Delete \"#{et.label}\"? Existing scoring events with this type will lose their point value." },
                class: "text-red-600 hover:text-red-500 bg-transparent border-0 cursor-pointer text-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
