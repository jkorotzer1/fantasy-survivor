<% if week.errors.any? %>
  <div class="mb-4 bg-red-50 border border-red-200 rounded p-3">
    <ul class="text-red-700 text-sm list-disc pl-4">
      <% week.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-4">
  <div>
    <%= f.label :number, "Week Number", class: "block text-sm font-medium text-gray-700" %>
    <%= f.number_field :number, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
  </div>
  <div>
    <%= f.label :air_date, class: "block text-sm font-medium text-gray-700" %>
    <%= f.date_field :air_date, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
    <p class="text-xs text-gray-500 mt-1">
      Picks lock automatically at <strong>8:00 PM Eastern</strong> on this date.
      <% if f.object.picks_locked_at.present? %>
        Currently: <%= f.object.picks_locked_at.in_time_zone("Eastern Time (US & Canada)").strftime("%b %d, %Y at %I:%M %p ET") %>
      <% end %>
    </p>
  </div>
  <div class="flex items-center gap-2">
    <%= f.check_box :scored, class: "rounded border-gray-300" %>
    <%= f.label :scored, "Scored", class: "text-sm font-medium text-gray-700" %>
  </div>
</div>
