<% if season.errors.any? %>
  <div class="mb-4 bg-red-50 border border-red-200 rounded p-3">
    <ul class="text-red-700 text-sm list-disc pl-4">
      <% season.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-4">
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :number, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :number, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
    </div>
    <div>
      <%= f.label :year, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :year, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
    </div>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :buy_in_cents, "Buy-in (cents)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :buy_in_cents, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
      <p class="text-xs text-gray-400 mt-1">e.g. 1000 = $10.00</p>
    </div>
    <div>
      <%= f.label :merge_week, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :merge_week, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
      <p class="text-xs text-gray-400 mt-1">Leave blank until known</p>
    </div>
  </div>
  <div>
    <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :status, Season.statuses.keys.map { |s| [s.capitalize, s] },
        {}, class: "mt-1 block w-full rounded border-gray-300 shadow-sm text-sm" %>
  </div>
</div>
