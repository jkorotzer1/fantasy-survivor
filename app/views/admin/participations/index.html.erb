<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Participations / Payments</h1>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Player</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Season</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Paid</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Action</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @participations.each do |p| %>
        <tr class="<%= p.paid_in? ? '' : 'bg-red-50' %>">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= p.user.display_name %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= p.season.name %></td>
          <td class="px-6 py-4">
            <% if p.paid_in? %>
              <span class="text-green-600 text-sm font-medium">✓ Paid</span>
            <% else %>
              <span class="text-red-600 text-sm font-medium">Unpaid</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-right space-x-2">
            <% unless p.paid_in? %>
              <%= button_to "Mark Paid", admin_participation_path(p),
                  method: :patch,
                  params: { participation: { paid_in: true } },
                  class: "bg-green-100 text-green-800 px-3 py-1 rounded text-xs font-medium hover:bg-green-200" %>
            <% end %>
            <%= button_to "Remove", admin_participation_path(p), method: :delete,
                data: { turbo_confirm: "Remove #{p.user.display_name} from #{p.season.name}? This will delete all their picks and scores." },
                class: "text-red-600 hover:text-red-500 bg-transparent border-0 cursor-pointer text-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>
