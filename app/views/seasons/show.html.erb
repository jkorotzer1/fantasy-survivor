<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-3xl font-bold text-gray-900"><%= @season.name %></h1>
    <p class="text-gray-500">Season <%= @season.number %> · <%= @season.year %></p>
  </div>
  <div class="flex gap-3">
    <%= link_to "Score Board", scores_season_path(@season), class: "bg-green-800 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-700" %>
    <%= link_to "Standings", standings_season_path(@season), class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-500" %>
    <%= link_to "Message Board", board_path, class: "bg-gray-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-gray-600" %>
    <% if @participation %>
      <%= link_to "My Picks", my_picks_season_path(@season), class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600" %>
    <% elsif user_signed_in? && @season.active? %>
      <% if @season.registration_open? %>
        <%= button_to "Join Season", season_participations_path(@season), method: :post,
            class: "bg-green-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-600" %>
      <% else %>
        <span class="bg-gray-200 text-gray-500 px-4 py-2 rounded text-sm font-medium cursor-not-allowed">Registration Closed</span>
      <% end %>
    <% end %>
  </div>
</div>

<div class="grid gap-8 lg:grid-cols-3">
  <!-- Weeks column -->
  <div class="lg:col-span-2">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Episodes</h2>
    <div class="space-y-3">
      <%
        current_week = @weeks.find { |w| !w.locked? }
      %>
      <% @weeks.each do |week| %>
        <%
          is_past    = week.picks_locked_at.present? && week.picks_locked_at < 6.hours.ago
          is_current = week == current_week
        %>
        <div class="bg-white rounded-lg shadow p-4 flex items-center justify-between <%= 'opacity-50' if is_past %>">
          <div>
            <span class="font-semibold <%= is_past ? 'text-gray-500' : 'text-gray-900' %>">
              <%= '🥥 ' if is_current %>Week <%= week.number %>
            </span>
            <% if week.air_date %>
              <span class="text-gray-500 text-sm ml-2"><%= week.air_date.strftime("%b %d, %Y") %></span>
            <% end %>
            <% if week.locked? && @picks_by_week %>
              <% pick = @picks_by_week[week.id] %>
              <div class="text-xs text-gray-500 mt-0.5">
                <% if pick %>Your Pick: <span class="font-medium text-gray-700"><%= pick.contestant.name %></span><% else %><span class="italic">No pick</span><% end %>
              </div>
            <% end %>
            <% if week.scored? %>
              <span class="ml-2 inline-flex items-center rounded-full bg-green-100 text-green-800 text-xs px-2 py-0.5">Scored</span>
            <% end %>
          </div>
          <div class="flex items-center gap-3">
            <% if week.locked? %>
              <span class="text-red-500 text-xs font-medium">Locked</span>
            <% elsif @participation %>
              <span class="text-green-600 text-xs font-medium" data-controller="countdown" data-countdown-deadline-value="<%= week.picks_locked_at.iso8601 %>">
                Picks open
              </span>
            <% end %>
            <%= link_to "View", season_week_path(@season, week), class: "text-blue-600 hover:text-blue-500 text-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <% if @participation %>
      <!-- Auto-pick toggle -->
      <div class="bg-white rounded-lg shadow p-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold text-gray-800">Auto-pick</p>
            <p class="text-xs text-gray-500 mt-0.5">If you forget to pick before the deadline, we'll randomly choose an eligible contestant for you.</p>
          </div>
          <%= button_to season_participation_path(@season, @participation),
              method: :patch,
              params: { auto_pick: @participation.auto_pick? ? "false" : "true" },
              class: "shrink-0 text-xs px-3 py-1.5 rounded font-medium #{@participation.auto_pick? ? 'bg-green-700 text-white hover:bg-green-600' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" do %>
            <%= @participation.auto_pick? ? "On" : "Off" %>
          <% end %>
        </div>
      </div>

      <!-- Winner Pick prompt -->
      <% unless @participation.has_winner_pick? %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
          <p class="text-sm text-yellow-800 mb-3 font-medium">Don't forget your winner pick!</p>
          <%= link_to "Make Winner Pick →", new_season_winner_pick_path(@season),
              class: "bg-yellow-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-yellow-500" %>
        </div>
      <% end %>
    <% end %>

    <!-- Contestants -->
    <div class="bg-white rounded-lg shadow p-4">
      <h2 class="text-lg font-semibold text-gray-800 mb-2">Castaways</h2>
      <%
        tribe_colors = {
          "vatu" => { dot: "bg-purple-500", badge: "bg-purple-100 text-purple-700" },
          "cila" => { dot: "bg-orange-500", badge: "bg-orange-100 text-orange-700" },
          "calo" => { dot: "bg-teal-500",   badge: "bg-teal-100 text-teal-700"   },
        }
      %>
      <!-- header -->
      <div class="flex items-center pb-1 mb-1 border-b border-gray-200 text-xs font-medium text-gray-400 uppercase gap-2">
        <span class="w-4 shrink-0"></span>
        <span class="flex-1">Castaway</span>
        <span>Past Tribes</span>
      </div>
      <% @season.contestants.sort_by { |c| [-c.all_tribes.size, c.tribe.to_s, c.name] }.each do |contestant| %>
        <% current_colors = tribe_colors[contestant.tribe] %>
        <div class="flex items-center py-1 border-b border-gray-100 last:border-0 gap-2">
          <!-- current tribe dot -->
          <span class="w-4 shrink-0 flex justify-center">
            <% if current_colors %>
              <span class="inline-block w-2.5 h-2.5 rounded-full <%= current_colors[:dot] %>"></span>
            <% end %>
          </span>
          <!-- name -->
          <span class="flex-1 text-sm text-gray-700"><%= contestant.name %></span>
          <!-- past tribes -->
          <span class="flex flex-wrap justify-end gap-x-2 gap-y-0.5">
            <% Array(contestant.previous_tribes).each do |t| %>
              <% t_name = t.is_a?(Hash) ? t["name"].to_s : t.to_s %>
              <% t_from = t.is_a?(Hash) ? t["from"] : nil %>
              <% t_to   = t.is_a?(Hash) ? t["to"]   : nil %>
              <% colors = tribe_colors[t_name] %>
              <span class="flex items-center gap-1 whitespace-nowrap text-xs text-gray-500">
                <% if t_from || t_to %><span>Wk <%= t_from %>–<%= t_to %></span><% end %>
                <% if colors %><span class="inline-block w-2 h-2 rounded-full <%= colors[:dot] %>"></span><% end %>
              </span>
            <% end %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</div>
