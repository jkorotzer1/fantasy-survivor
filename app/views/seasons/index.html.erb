<h1 class="text-3xl font-bold text-gray-900 mb-6">All Seasons</h1>

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  <% @seasons.each do |season| %>
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-lg font-bold text-gray-900"><%= season.name %></h2>
          <p class="text-gray-500 text-sm">Season <%= season.number %> · <%= season.year %></p>
        </div>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
          <%= season.active? ? 'bg-green-100 text-green-800' : season.upcoming? ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-800' %>">
          <%= season.status.capitalize %>
        </span>
      </div>
      <p class="text-gray-600 text-sm mt-2">Buy-in: $<%= format("%.2f", season.buy_in_dollars) %></p>
      <div class="mt-4 flex gap-2">
        <%= link_to "View", season_path(season), class: "text-green-700 hover:text-green-600 text-sm font-medium" %>
        <%= link_to "Standings", standings_season_path(season), class: "text-blue-600 hover:text-blue-500 text-sm font-medium" %>
      </div>
    </div>
  <% end %>
</div>
